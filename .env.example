# ── Copy this file to .env and fill in your keys ─────────────────────────────
#
# Setting GEMINI_API_KEY enables AI-generated session reports using the
# Google Gemini API (free tier — no credit card required).
# If it is not set, the server uses a built-in template report instead —
# the system is fully functional without any API key.
#
# Get your free API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash   ← default (free tier, fast); other options:
#                                    gemini-1.5-flash  (also free)
#                                    gemini-1.5-pro    (limited free quota)

# ── Whisper audio transcription (optional) ────────────────────────────────────
# Controls which Whisper model size is loaded at startup.
# Larger models are more accurate but slower and use more RAM.
# Options: tiny (~75 MB) | base (~145 MB) | small (~460 MB) | medium (~1.5 GB) | large (~3 GB)
# Omit or leave blank to use the default (base).
# WHISPER_MODEL=base
